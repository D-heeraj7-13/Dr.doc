import requests
import json
import time
import re
from datetime import datetime, timezone, timedelta
from html import unescape

# ─── CONFIG ─────────────────────────────────────────────
 
BASE_URL = "https://api.worldnewsapi.com/search-news"

MAX_PER_REQUEST = 100          # WorldNewsAPI default max is 100
TOTAL_RESULTS_REQUIRED = 500   # adjust as needed (API has quotas)

IST = timezone(timedelta(hours=5, minutes=30))

# ─── FETCH MODE ─────────────────────────────────────────
FETCH_MODE = "today"           # "today" or "last_n_days"
LAST_N_DAYS = 7                # only used if FETCH_MODE == "last_n_days"

# ─── KEYWORD GROUPS (same as yours) ─────────────────────
KEYWORD_GROUPS = {
    "Geojit": ["Geojit", "Geojit Financial Services", "जियोजित"],
    "Zerodha": ["Zerodha", "ज़ेरोधा"],
    "Angel One": ["Angel One", "Angel Broking"],
    "Groww": ["Groww"],
    "Kotak Securities": ["Kotak Securities", "कोटक सिक्योरिटीज"],
    "ICICI Securities": ["ICICI Securities", "आईसीआईसीआई सिक्योरिटीज"],
    "Motilal Oswal": ["Motilal Oswal", "मोतीलाल ओसवाल"]
}

# ─── HELPERS ────────────────────────────────────────────
def get_time_range():
    now_utc = datetime.now(timezone.utc)
    if FETCH_MODE == "today":
        # Start of today in IST → converted to UTC
        now_ist = now_utc + IST.utcoffset(None)
        today_start_ist = now_ist.replace(hour=0, minute=0, second=0, microsecond=0)
        since_utc = today_start_ist - IST.utcoffset(None)
    else:
        since_utc = now_utc - timedelta(days=LAST_N_DAYS)
    
    return since_utc, now_utc

def to_ist(dt_str):
    try:
        # WorldNewsAPI returns ISO format like "2026-04-27T10:15:00Z" or without Z
        dt = datetime.fromisoformat(dt_str.replace("Z", "+00:00"))
        return (dt + IST.utcoffset(None)).strftime("%Y-%m-%d %H:%M IST")
    except Exception:
        return "Unknown date"

def clean_html(text):
    if not text:
        return ""
    text = re.sub(r"<[^>]+>", " ", text)
    text = unescape(text)
    return re.sub(r"\s+", " ", text).strip()

def get_matched_keywords(title, body, keywords):
    combined = f"{title} {body}".lower()
    return [kw for kw in keywords if kw.lower() in combined]

def get_sentiment(text):
    pos = ["gain", "rise", "up", "positive", "growth", "profit", "bullish"]
    neg = ["loss", "fall", "down", "negative", "decline", "weak", "bearish"]
    text = text.lower()
    score = sum(w in text for w in pos) - sum(w in text for w in neg)
    if score > 0: return "positive"
    elif score < 0: return "negative"
    return "neutral"

def build_query(keywords):
    """Exact phrase match with OR"""
    return " OR ".join(f'"{k}"' for k in keywords)
